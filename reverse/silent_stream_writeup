def decode_byte(b, key):
    return (b - key) % 256

def simulate_flag_transfer(filename, key=42):

    with open(filename, "rb") as f:
        data = f.read()

    decoded_data = bytes(decode_byte(b, key) for b in data)
    with open("decoded_flag.jpeg", "wb") as f:
        f.write(decoded_data)

if __name__ == "__main__":
    simulate_flag_transfer("rawbits.txt")

